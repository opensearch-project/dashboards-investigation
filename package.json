{
  "name": "dashboards-investigation",
  "version": "3.8.0.0",
  "main": "index.ts",
  "license": "Apache-2.0",
  "scripts": {
    "osd": "node ../../scripts/osd",
    "build": "yarn plugin-helpers build",
    "test": "../../node_modules/.bin/jest --config ./test/jest.config.js",
    "plugin-helpers": "node ../../scripts/plugin_helpers",
    "prepare": "husky install",
    "lint:es": "node ../../scripts/eslint",
    "lint": "yarn lint:es"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      ".husky/hooks/check-test-only.sh",
      "yarn lint --fix"
    ]
  },
  "dependencies": {
    "autosize": "^6.0.1",
    "dompurify": "^3.4.11",
    "html2canvas-pro": "^1.6.6",
    "lodash": "^4.18.0",
    "lru-cache": "^4.1.5",
    "performance-now": "^2.1.0",
    "semver": "^7.5.2"
  },
  "devDependencies": {
    "@types/autosize": "^4.0.3",
    "fake-indexeddb": "^6.1.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.10"
  },
  "resolutions": {
    "ansi-regex": "^5.0.1"
  },
  "eslintIgnore": [
    "node_modules/*",
    "target/*"
  ]
}
